<%- include('layouts/header') %>
<%- include('layouts/navbar') %>

<section class="page-section" style="padding-top: 150px; min-height: 85vh;" id="portfolio">
    <div class="container">
        <h2 class="page-section-heading text-center text-uppercase text-secondary mb-0">
            <%= title %>
        </h2>
        
        <div class="divider-custom">
            <div class="divider-custom-line"></div>
            <div class="divider-custom-icon"><i class="fas fa-star"></i></div>
            <div class="divider-custom-line"></div>
        </div>

        <div class="row justify-content-center">
            <% clubs.forEach(club => { %>  
                <div class="col-md-6 col-lg-4 mb-5">
                    <div class="card h-100 border-0 shadow-lg" style="border-radius: 15px;">
                        <div class="card-body p-4 text-center"> 
                            <h4 class="fw-bold text-secondary text-uppercase"><%= club.name %></h4> 
                            <p class="text-muted"><%= club.desc %></p>
                            
                            <div class="mb-3">
                                <% if(club.hot) { %>  
                                    <span class="badge rounded-pill bg-danger px-3 py-2">🔥 Nổi bật</span>  
                                <% } else { %>
                                    <span class="badge rounded-pill bg-secondary px-3 py-2">Thường</span> 
                                <% } %>
                            </div>

                            <a href="/detail/<%= club.id %>" class="btn btn-primary rounded-pill px-4" style="background-color: #1abc9c; border: none;">
                                <i class="fas fa-info-circle"></i> Xem chi tiết
                            </a>  
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>
</section>

<%- include('layouts/footer') %>